# =============================================================================
# Masraf Yönetim Sistemi — Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# GERÇEK .env DOSYASINI ASLA GİT'E GÖNDERMEYİN.
# Gizli değerleri üretmek için: bash scripts/generate-secrets.sh
# =============================================================================

# ── Genel ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Servis portları (lokal geliştirme) ────────────────────────────────────────
WEB_PORT=3000
API_PORT=4000

# ── Servis adresleri ──────────────────────────────────────────────────────────
# Lokal geliştirme:
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# Frontend Vite build değişkeni — tarayıcıya gömülür.
# Production (Northflank): /api/v1  (relative — Nginx proxy üzerinden)
# Lokal geliştirme:         http://localhost:4000/api/v1
VITE_API_URL=http://localhost:4000/api/v1

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# DATABASE_URL: Neon pooler bağlantısı (uygulama runtime'ında kullanır)
#   Neon paneli → Project → Connection Details → "Pooled connection" seçin
#   Bağlantı modu: Transaction (PgBouncer)
DATABASE_URL=postgresql://user:password@ep-xxx.pooler.us-east-2.aws.neon.tech/masraf?sslmode=require

# DIRECT_URL: Neon doğrudan bağlantısı (yalnızca prisma migrate / generate)
#   Neon paneli → Project → Connection Details → "Direct connection" seçin
#   Pooler olmayan endpoint; migration'lar SET TRANSACTION kullanır, pooler uyumsuzdur.
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/masraf?sslmode=require

# Lokal geliştirme (docker-compose postgres servisi):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/masraf?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/masraf?schema=public

# ── JWT Kimlik Doğrulama ──────────────────────────────────────────────────────
# Üretimde en az 32 karakterlik rastgele değerler: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Cookie imzalama ───────────────────────────────────────────────────────────
COOKIE_SECRET=change-me-cookie-secret-minimum-32-chars

# ── Cloudflare R2 Dosya Depolama ──────────────────────────────────────────────
# Bucket PRIVATE olmalıdır. Dosyalara yalnızca signed URL ile erişilir.
# R2 paneli → Account → R2 → API Tokens → "Create API Token" (bucket-specific Read+Write)
STORAGE_PROVIDER=s3
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=masraf-attachments
R2_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
R2_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
R2_FORCE_PATH_STYLE=false
R2_SIGNED_URL_TTL_SECONDS=900

# Lokal geliştirme (MinIO — docker-compose minio servisi):
# R2_ENDPOINT=http://localhost:9000
# R2_REGION=auto
# R2_BUCKET=masraf-attachments
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_FORCE_PATH_STYLE=true

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ── Loglama ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── E-posta / SMTP (opsiyonel — bildirimler) ──────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ── Hata izleme (opsiyonel) ───────────────────────────────────────────────────
SENTRY_DSN=

# ── Docker Compose (lokal postgres) ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=masraf
