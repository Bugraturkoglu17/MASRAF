# =============================================================================
# Masraf Yönetim Sistemi - Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# GERÇEK .env DOSYASINI ASLA GIT'E GÖNDERMEYİN.
# =============================================================================

# --- Genel ---
NODE_ENV=development

# --- Servis portları ---
WEB_PORT=3000
API_PORT=4000

# --- Servis adresleri ---
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
VITE_API_URL=http://localhost:4000/api/v1

# --- Veritabanı (PostgreSQL) ---
# docker-compose ile lokal geliştirmede host adı "postgres" olur.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/masraf?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=masraf

# --- JWT Kimlik Doğrulama ---
# Üretimde en az 32 karakterlik rastgele değerler kullanın: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Cookie imzalama ---
COOKIE_SECRET=change-me-cookie-secret-minimum-32-chars

# --- Dosya Depolama (S3 uyumlu) ---
# Lokal geliştirme için MinIO değerleri docker-compose.yml içinde tanımlıdır.
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=masraf-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# --- Loglama ---
LOG_LEVEL=info

# --- E-posta (SMTP) - şifre sıfırlama ve bildirimler için genişletilebilir ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# --- Hata izleme (opsiyonel) ---
SENTRY_DSN=
