{
  "name": "masraf-yonetim-sistemi",
  "version": "0.1.0",
  "private": true,
  "description": "Masraf Yönetim Sistemi - monorepo",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "db:migrate": "pnpm --filter @masraf/api db:migrate",
    "db:generate": "pnpm --filter @masraf/api db:generate",
    "db:seed": "pnpm --filter @masraf/api db:seed",
    "db:studio": "pnpm --filter @masraf/api db:studio",
    "db:deploy": "pnpm --filter @masraf/api db:deploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "apps/api/**/*.ts": "eslint --fix -c apps/api/eslint.config.js",
    "apps/web/**/*.{ts,tsx}": "eslint --fix -c apps/web/eslint.config.cjs",
    "packages/shared-types/**/*.ts": "eslint --fix -c packages/shared-types/eslint.config.js",
    "packages/shared-validation/**/*.ts": "eslint --fix -c packages/shared-validation/eslint.config.js",
    "*.{ts,tsx,js,jsx,cjs,json,md}": "prettier --write"
  }
}
